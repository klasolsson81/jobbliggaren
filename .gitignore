# Claude Code — personal session state
.claude/settings.local.json
.claude/auto-memory/
# Maskin-genererade artefakter från hooks (session-history, pre-compact snapshots)
.claude/logs/
.claude/backups/
.claude/tasks/
.claude/scheduled_tasks.lock
# Per-worktree provenance marker (worktree-reaper, issue #673) — one per worktree
# root, never committed; must stay ignored so it never dirties the reaper clean-check.
# The trailing * also covers the transient .tmp.<pid> write file (atomic write + mv).
.jbl-worktree.json*

# Environment files (dev secrets)
.env
.env.local
.env.*.local
appsettings.Local.json

# RSA keys and other local secrets (never commit)
.secrets/

# #560 (ADR 0091) — SCB client certificates + provisioning docs (personal credential, never commit).
# gitleaks is text/regex-based and can miss a binary .pfx, so this ignore is the load-bearing guard
# against an accidental `git add` of the cert (contract breach + API-Id ban risk).
*.pfx
*.p12
docs/scb/

# Fas 4 STEG C — machine-generated motor-stresstest findings report (regenerated via
# `dotnet test`; the emitter is the committed deliverable, the artifact is not)
tests/Jobbliggaren.QA.Corpus/artifacts/

# .NET build artifacts
bin/
obj/
*.user
.vs/
TestResults/
coverage/
*.coverage
# In-repo coverage-artefakter (ADR 0044) — aldrig committade
artifacts/

# Lokal jobbar-mapp för temp-artefakter (Flux brand-iterationer F-Pre Punkt 6, lokala dumps).
# Security-auditor 2026-05-25: aldrig in i prod-bundle eller git-historik.
tmp/

# Node / Next.js
node_modules/
.husky/_/
.next/
out/
.turbo/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# IDE
.idea/

# Terraform
**/.terraform/
*.tfstate
*.tfstate.*
*.tfstate.backup
crash.log
crash.*.log
*.tfplan
plan.out
override.tf
override.tf.json
*_override.tf
*_override.tf.json
# NOTE: keep .terraform.lock.hcl committed per provider-pinning best practice.

# Precompact-rapporter är temporära debug-artefakter
docs/sessions/precompact-*.md

# Startprompt-filer för CC-sessioner (temporära handoffs mellan sessioner)
STARTPROMPT-*.md

# Terraform plan/apply-outputs — kan innehålla känsliga värden från state/secrets
infra/terraform/**/*.out

# Visual Studio language-service cache (IDE-artefakt, ej källkod)
*.lscache

# ── Docs-privacy: curated publik fasad (ADR 0072) ──────────────────────────
# Operativ/strategisk dokumentation hålls lokalt, ej i publika repot.
# Borttagning gjord via history-purge (git filter-repo, ADR 0072). Lokala kopior hålls ignorerade.
docs/sessions/
docs/research/
docs/design/
# Opublicerade legal-utkast (Klas-sign-off krävs före publicering; wiring sker via i18n, inte MD-filerna)
docs/legal/
docs/handoff-banner/
docs/handoff-oversikt/
docs/jobbpilot-v3-bundle/
docs/current-work.md
docs/current-work-archive.md
docs/steg-tracker.md
docs/tech-debt.md
docs/tech-debt-archive.md
# Strategi-avslöjande ADR:er (go-to-market + interna riktningsbeslut)
docs/decisions/0005-go-to-market-strategy.md
docs/decisions/0071-*.md
docs/decisions/0072-*.md
docs/decisions/0073-*.md
# Autonomt multi-session-flöde (2026-06-25, Klas-beslut): agent-review-rapporter
# och nyare ADR:er hålls lokala by-default. Globen nedan matchar ADR 0070–0099;
# redan spårade ADR 0001–0073 + 234 reviews FÖRBLIR publika (gitignore avspårar
# inte redan committade filer), så nettoeffekten är "nya ADR:er 0074+ blir lokala".
# Vid ADR 0100+ måste ett nytt mönster läggas till (00[789][0-9] täcker ej 0100+).
# Främja en lokal ADR/review till publikt via `git add -f`.
docs/reviews/
docs/decisions/00[789][0-9]-*.md
# Infra-/admin-runbooks (AWS-era + RBAC-bootstrap)
docs/runbooks/admin-bootstrap.md
docs/runbooks/aws-cost-recovery.md
docs/runbooks/aws-rds-migration-apply.md
docs/runbooks/aws-setup.md
# GDPR Art. 30 processing-register (ROPA) — internal accountability record, not
# public (names sub-processors + infra topology); local-only per ADR 0072 (#183).
docs/runbooks/gdpr-processing-register.md
# Lokala loadtest-artefakter
loadtest-reports/
