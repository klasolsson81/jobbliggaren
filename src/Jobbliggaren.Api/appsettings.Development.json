{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Seq": {
    "ServerUrl": "http://localhost:5341"
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5435;Database=jobbliggaren;Username=jobbliggaren;Password=${POSTGRES_PASSWORD_DEV}",
    "Redis": "localhost:6379"
  },
  "Jwt": {
    "Issuer": "https://localhost:5000",
    "Audience": "jobbliggaren-api",
    "AccessTokenLifetimeMinutes": 15,
    "RefreshTokenLifetimeDays": 14,
    "PrivateKeyPath": ".secrets/jwt-private-key.pem",
    "PublicKeyPath": ".secrets/jwt-public-key.pem"
  },
  "AdminBootstrap": {
    "InitialAdminEmail": ""
  },
  "RateLimiting": {
    "_comment": "DEV-ONLY generösa limits så normal bläddring/testning inte rate-limit:as (prod-talen i RateLimitingOptions är orörda; sanktionerat av options-designen: 'Test-miljöer höjer limits'). Prod-retune av talen+algoritmen routas separat till senior-cto-advisor + security-auditor (2026-06-24).",
    "MeListRead": { "PermitLimit": 600, "WindowSeconds": 60 },
    "ListRead": { "PermitLimit": 600, "WindowSeconds": 60 },
    "FacetCounts": { "PermitLimit": 300, "WindowSeconds": 10 },
    "Suggest": { "PermitLimit": 300, "WindowSeconds": 10 },
    "TaxonomyRead": { "PermitLimit": 300, "WindowSeconds": 60 },
    "MeWrite": { "PermitLimit": 300, "WindowSeconds": 60 },
    "JobAdStatusBatch": { "PermitLimit": 600, "WindowSeconds": 60 },
    "JobAdMatchBatch": { "PermitLimit": 600, "WindowSeconds": 60 },
    "AuthWrite": { "PermitLimit": 200, "WindowSeconds": 60 },
    "AuthLoose": { "PermitLimit": 300, "WindowSeconds": 60 }
  }
}
